	program final
	type
	rango = 1..12;
		publicacion = record
			titulo: string;
			nombreautor: string;
			dniautor: integer;
			tipopubli: rango
		end;
	lista : ^nodo;
	nodo = record
		dato : publicacion;}
		sig : lista;
	end;
	
	vector = array [rango] of integer;
	
	procedure leer(var p:publicacion);
	begin
		readln(p.dniautor);
		if (p.dniautor <> 0) then begin
			readln(p.titulo);
			readln(p.nombreautor);
			readln(p.tipopubli);
		end;
	end;
	
	procedure insertar(var l:lista; p: publicacion);
	var nue,act,ant:lista;
	begin
		new(nue);
		nue^.dato := p;
		nue^.sig := nil;
		if (l = nil) then
			l := nue
		else begin
			act := l;
			while (act <> nil) and (p.dniautor < act^.dato.dniautor) do begin
				ant := act;
				act := act^.sig;
			end;
			if (act = l) then begin
				nue^.sig := l;
				l := nue;
			end
			else
				ant^.sig :=  nue;
			nue^.sig := act;
		end;
	end;
	
	procedure cargarLista(var l:lista; var v:vector);
	var p:publi;
	begin
		leer(p);
		while (p.dniautor <> 0) do begin
			insertar(l,p);
			v[p.tipopubli] := v[p.tipopubli] + 1;
			leer(p);
		end;
	end;
	
	procedure recorrer(l:lista);
	var cant,act:integer;
	begin
		while (l <> nil) do begin
			act := l^.dato.dniautor;
			while(l <> nil) and (act = l^.dato.dniautor) do begin
				cant: cant + 1;
				l := l^.sig;
			end;
			writeln('la cantidad de publicaciones del autor ', act , ' son ', cant);
		end;
	end;
	
	procedure maxtipo(v:vector; var tipo:integer);
	var
		max: integer;
	begin
		max := -1;
		for i := 1 to 12 do begin
			if (v[i] < max) then begin
				max := v[i];
				tipo := i;
			end;
		end;
	end;
	
	var
		l : lista; v:vector; tipo :integer;
	begin
	l := nil;
	cargarLista(l,vec);
	recorrer(l);
	maxtipo(v,tipo);
	writeln('el tipo de publicacion con mas presentaciones es ',tipo);
	end;
	
