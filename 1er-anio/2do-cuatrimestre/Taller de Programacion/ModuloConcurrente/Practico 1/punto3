programa ejemplo
procesos
  proceso juntarP(ES papeles : numero)
  comenzar
    si (HayPapelEnLaEsquina)
      mientras (HayPapelEnLaEsquina)
        tomarPapel
        papeles := papeles + 1
    si HayPapelEnLaBolsa
      mientras HayPapelEnLaBolsa 
        depositarPapel
  fin
  proceso juntarF(ES flores: numero)
  comenzar
    si (HayFlorEnLaEsquina)
      mientras (HayFlorEnLaEsquina)
        tomarFlor
        flores := flores + 1
    si HayFlorEnLaBolsa
      mientras HayFlorEnLaBolsa
        depositarFlor
  fin
  proceso escalon(E altura:numero; E ancho:numero; ES cant: numero)
  variables
    papeles: numero
    flores: numero
    resultado: numero
  comenzar
    papeles := 0
    flores := 0
    repetir altura
      juntarP(papeles)
      juntarF(flores)
      mover
      derecha
      repetir ancho
        juntarP(papeles)
        juntarF(flores)
        mover
      repetir 3
        derecha
      resultado := papeles - flores
      si (resultado =  1)
        cant := cant + 1
  fin
