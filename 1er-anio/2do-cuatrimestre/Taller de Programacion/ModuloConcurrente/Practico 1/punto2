programa ejemplo
procesos
  proceso juntarPapel(ES cant: numero)
  comenzar
    si (HayPapelEnLaEsquina)
      mientras (HayPapelEnLaEsquina)
        tomarPapel
        cant := cant + 1
  fin
  proceso cuadrado1(E lado:numero; ES papeles: numero)
  comenzar
    repetir 4
      repetir lado
        juntarPapel(papeles)
        mover
      derecha
  fin
  proceso cuadrado2(E lado:numero; ES pap:numero)
  comenzar
    derecha
    repetir 4
      repetir lado
        juntarPapel(pap)
        mover
      derecha
  fin
  proceso cuadrado3(E lado:numero; ES papel:numero)
  comenzar
    repetir 2
      derecha
    repetir 4
      repetir lado
        juntarPapel(papel)
        mover
      derecha
  fin
  proceso cuadrado4(E lado:numero; ES papel:numero)
  comenzar
    repetir 3
      derecha
    repetir 4
      repetir lado
        juntarPapel(papel)
        mover
      derecha
  fin
