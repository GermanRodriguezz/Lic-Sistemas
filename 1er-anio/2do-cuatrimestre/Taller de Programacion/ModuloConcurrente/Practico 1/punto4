programa ejemplo
procesos
  proceso recorridoPar(E numAv: numero)
  comenzar
    Pos(numAv,1)
    repetir 99
      si (HayPapelEnLaEsquina)
        mientras (HayPapelEnLaEsquina)
          tomarPapel
      mover
  fin
  proceso LimpiezaPar(E posAv:numero)
  comenzar
    repetir 25
      recorridoPar(posAv)
      posAv := posAv + 1
  fin
  proceso recorridoImpar(E numAv: numero)
  comenzar
    Pos(numAv,1)
    repetir 99
      si (HayFlorEnLaEsquina)
        mientras (HayFlorEnLaEsquina)
          tomarFlor
      mover
  fin
  proceso LimpiezaImpar(E posAv: numero)
  comenzar
    repetir 25
      recorridoImpar(posAv)
      posAv := posAv + 1
  fin
areas
