  robot servidor
  variables
    id,num,av,ca,flores:numero
    termino: boolean
  comenzar
    repetir 9
      Random(num,1,5)
      RecibirMensaje(id,*)
      si (id = 1)
        EnviarMensaje(num,r1)
      sino
        si (id = 2)
          EnviarMensaje(num,r2)
        sino
          si (id = 3)
            EnviarMensaje(num,r3)
    repetir 3
      RecibirMensaje(termino,*)
    av:= PosAv
    ca:= PosCa
    flores:=0
    buscar(av,ca,flores)
    Informar('tomo la cantidad',flores)
  fin
