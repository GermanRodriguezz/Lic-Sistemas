programa ejemplo
procesos
  proceso buscar(E av: numero; E ca: numero; ES e:boolean)
  variables
    x,y:numero
  comenzar
    x := PosAv
    y := PosCa
    BloquearEsquina(av,ca)
    Pos(av,ca)
    si (HayFlorEnLaEsquina)
      tomarFlor
      e := V
    Pos(x,y)
    LiberarEsquina(av,ca)
  fin
areas
  Punto  : AreaC (10,10,13,13)
  arear1 : AreaP (2,2,2,2)
  arear2 : AreaP (3,3,3,3)
  arear3 : AreaP (4,4,4,4)
  areaE  : AreaP (1,1,1,1)
robots
  robot buscador
  variables
    encontre,encontraron: boolean
    av,ca,id: numero
  comenzar
    RecibirMensaje(id,re)
    mientras (encontre <> V) & (encontraron <> V)
      Random(av,10,13)
      Random(ca,10,13)
      buscar(av,ca,encontre)
      si (id = 1)
        EnviarMensaje(encontre,r2)
        EnviarMensaje(encontre,r3)
        RecibirMensaje(encontraron,r2)
        RecibirMensaje(encontraron,r3)
      sino
        si (id = 2)
          EnviarMensaje(encontre,r1)
          EnviarMensaje(encontre,r3)
          RecibirMensaje(encontraron,r1)
          RecibirMensaje(encontraron,r3)
        sino
          si (id = 3)
            EnviarMensaje(encontre,r1)
            EnviarMensaje(encontre,r2)
            RecibirMensaje(encontraron,r1)
            RecibirMensaje(encontraron,r2)
    si (encontre = V)
      EnviarMensaje(id,re)
  fin
  robot escondedor
  variables
    av,ca,x,y,id,idGanador: numero
  comenzar
    si (HayFlorEnLaEsquina)
      tomarFlor
    Random(av,10,13)
    Random(ca,10,13)
    x := PosAv
    y := PosCa
    Pos(av,ca)
    si (HayFlorEnLaBolsa)
      depositarFlor
    Pos(x,y)
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    RecibirMensaje(id,*)
    si (id = 1)
      idGanador := 1
    sino
      si (id = 2)
        idGanador := 2
      sino
        si (id = 3)
          idGanador := 3
    Informar('quien encontro la flor fue el rob ',idGanador)
  fin
variables
  r1: buscador
  r2: buscador
  r3: buscador
  re: escondedor
comenzar
  AsignarArea(re, Punto)
  AsignarArea(re,areaE)
  AsignarArea(r1,arear1)
  AsignarArea(r1,Punto)
  AsignarArea(r2,arear2)
  AsignarArea(r2,Punto)
  AsignarArea(r3,arear3)
  AsignarArea(r3,Punto)
  Iniciar(re, 1,1)
  Iniciar(r1, 2,2)
  Iniciar(r2, 3,3)
  Iniciar(r3, 4,4)
fin