programa ejemplo
procesos
  proceso escalon(E alto: numero; E ancho : numero; ES p: numero)
  comenzar
    repetir alto
      mientras (HayPapelEnLaEsquina)
        tomarPapel
        p := p + 1
      mover
    derecha
    repetir ancho
      mientras (HayPapelEnLaEsquina)
        tomarPapel
        p := p + 1
      mover 
    repetir 3
      derecha
  fin
  proceso depositar
  variables
    x,y: numero
  comenzar
    x := PosAv
    y := PosCa
    BloquearEsquina(100,100)
    Pos(100,100)
    si (HayPapelEnLaBolsa)
      depositarPapel
    Pos(x,y)
    LiberarEsquina(100,100)
  fin
  proceso sacarMax(E p1: numero; E p2: numero; E p3: numero; ES idMax: numero)
  variables
    max : numero
  comenzar
    max := -1
    si (p1 > max)
      max := p1
      idMax := 1
    si (p2 > max)
      max := p2
      idMax := 2
    si (p3 > max)
      max := p3
      idMax := 3
  fin
