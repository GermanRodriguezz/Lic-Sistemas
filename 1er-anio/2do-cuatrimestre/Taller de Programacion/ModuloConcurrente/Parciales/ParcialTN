robots
  robot papelero
  variables
    id,ancho,alto,papeles: numero
  comenzar
    RecibirMensaje(id,rf)
    RecibirMensaje(alto,rf)
    RecibirMensaje(ancho,rf)
    papeles := 0
    repetir 3
      escalon(alto,ancho,papeles)
    repetir papeles
      depositar
    EnviarMensaje(id,rf)
    EnviarMensaje(papeles,rf)      
  fin
  robot fiscal
  variables
    id,alto,ancho,p1,p2,p3,papeles,idMax: numero
  comenzar
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    
    Random(alto,1,4)
    EnviarMensaje(alto,r1)
    Random(ancho,1,3)
    EnviarMensaje(ancho,r1)
    
    Random(alto,1,4)
    EnviarMensaje(alto,r2)
    Random(ancho,1,3)
    EnviarMensaje(ancho,r2)
    
    Random(alto,1,4)
    EnviarMensaje(alto,r3)
    Random(ancho,1,3)
    EnviarMensaje(ancho,r3)
    
    repetir 3
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(papeles,r1)
        p1 := papeles
      sino
        si (id = 2)
          RecibirMensaje(papeles,r2)
          p2 := papeles
        sino
          si (id = 3)
            RecibirMensaje(papeles,r3)
            p3 := papeles
    sacarMax(p1,p2,p3,idMax)
    Informar('el rob que junto mas papeles fue ', idMax)
  fin
