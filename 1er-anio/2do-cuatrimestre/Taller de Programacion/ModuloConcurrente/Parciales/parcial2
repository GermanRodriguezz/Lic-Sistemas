procesos
  proceso Cuadrado(E num: numero;ES flores:numero)
  comenzar
    repetir 2
      repetir num
        mientras (HayFlorEnLaEsquina)
          tomarFlor
          flores:= flores + 1
        mover
      derecha
      repetir num
        mientras (HayFlorEnLaEsquina)
          tomarFlor
          flores:= flores + 1
        mover
      derecha
  fin
  proceso actMax(E cant:numero; ES max:numero;ES robMax:numero; E nRob:numero)
  comenzar
    si (cant > max)
      max:= cant
      robMax:= nRob
  fin
