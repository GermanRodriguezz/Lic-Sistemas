    sino
      si (PosAv = 7)
        id := 2
      sino
        si (PosAv = 14)
          id:= 3
    cantCuadras:= 0
    repetir 3
      f:= 0
      Random(num,1,4)
      avIni:= PosAv
      calleProx:= PosCa + num + 1{calle donde comienzo el otro cuadrado}
      Cuadrado(num,f)
      cantCuadras := cantCuadras + (num * 4)
      EnviarMensaje(id,rc)
      EnviarMensaje(cantCuadras,rc)
      BloquearEsquina(50,50)
      Pos(50,50)
      repetir f
        depositarFlor
      Pos(avIni,calleProx)
      LiberarEsquina(50,50)
  fin
  robot coordinador
  variables
    cantidadCuadras,cuadrasR1,cuadrasR2,cuadrasR3,maxRob,max,idRob:numero
  comenzar
    max:= 0
    repetir 9
      RecibirMensaje(idRob,*)
      si (idRob = 1)
        RecibirMensaje(cantidadCuadras,r1)
        cuadrasR1:= cuadrasR1 + cantidadCuadras
        actMax(cuadrasR1,max,maxRob,idRob)
      sino
        si (idRob = 2)
          RecibirMensaje(cantidadCuadras,r2)
          cuadrasR2:= cuadrasR2 + cantidadCuadras
          actMax(cuadrasR2,max,maxRob,idRob)
        sino
          si (idRob = 3)
            RecibirMensaje(cantidadCuadras,r3)
            cuadrasR3:= cuadrasR3 + cantidadCuadras
            actMax(cuadrasR3,max,maxRob,idRob)
    Informar('el rob que hizo maximas cuadras fue',maxRob)
  fin
