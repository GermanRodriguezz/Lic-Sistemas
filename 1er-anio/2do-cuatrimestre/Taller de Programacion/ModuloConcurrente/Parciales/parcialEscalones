programa ejemplo
procesos
  proceso depositar
  variables
    x,y: numero
  comenzar
    x:= PosAv
    y:= PosCa
    BloquearEsquina(99,99)
    Pos(99,99)
    mientras (HayPapelEnLaBolsa)
      depositarPapel
    Pos(x,y)
    LiberarEsquina(99,99)
  fin
  proceso escalon(E alto: numero; E ancho:numero;ES esquinas:numero)
  variables
    esquinas: numero
  comenzar
    esquinas:=0
    repetir alto
      si (HayPapelEnLaEsquina)
        mientras (HayPapelEnLaEsquina)
          tomarPapel
        esquinas:= esquinas + 1
      mover
    depositar
    derecha
    repetir ancho
      si (HayPapelEnLaEsquina)
        mientras (HayPapelEnLaEsquina)
          tomarPapel
        esquinas:= esquinas + 1
      mover
    depositar
    repetir 3
      derecha
  fin
areas
