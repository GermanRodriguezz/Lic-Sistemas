robots
  robot papelero
  variables
    alt,anc,id,esquinas:numero
    podes:boolean
  comenzar
    RecibirMensaje(id,rf)
    esquinas:=0
    repetir 4
      Random(alt,1,3)
      Random(anc,2,4)
      RecibirMensaje(podes,rf)
      escalon(alt,anc,esquinas)
      EnviarMensaje(V,rf)
    EnviarMensaje(id,rf)
    EnviarMensaje(esquinas,rf)
  fin
  robot fiscal
  variables
    Termino: boolean
    id,esq1,esq2,esq3,total:numero
  comenzar
    total:=0
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    repetir 4
      EnviarMensaje(V,r1)
      EnviarMensaje(V,r2)
      EnviarMensaje(V,r3)
      repetir 3
        RecibirMensaje(Termino,*)
    repetir 3
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(esq1,r1)
        total:= total + esq1
      sino
        si (id = 2)
          RecibirMensaje(esq2,r2)
          total:= total + esq2
        sino
          si (id = 3)
            RecibirMensaje(esq3,r3)
            total:= total + esq3
    Pos(99,99)
    mientras (HayPapelEnLaEsquina)
      tomarPapel
    Informar('el total de esquinas es',total)
  fin
