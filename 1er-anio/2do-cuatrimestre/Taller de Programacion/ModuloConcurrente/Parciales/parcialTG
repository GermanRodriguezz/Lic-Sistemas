procesos
  proceso limpiar(ES f:numero; ES p:numero)
  comenzar
    mientras (HayFlorEnLaEsquina)
      tomarFlor
      f := f +1
    mientras (HayPapelEnLaEsquina)
      tomarPapel
      p := p + 1
  fin
  proceso depositar(E av:numero; E ca:numero)
  variables
    x,y:numero
  comenzar
    x := PosAv
    y := PosCa
    BloquearEsquina(av,ca)
    Pos(av,ca)
    si (HayFlorEnLaBolsa)
      depositarFlor
    Pos(x,y)
    LiberarEsquina(av,ca)
  fin
  proceso LimpiarAvenidaPar
  variables
    av,ca,id,f,p,avenida,calle:numero
  comenzar
    av := PosAv
    repetir 4
      Pos(av,1)
      repetir 99
        limpiar(f,p)
        mover
      RecibirMensaje(avenida,rc)
      RecibirMensaje(calle,rc)
      repetir f
        depositar(avenida,calle)
      repetir p
        depositar(avenida,calle)
      av := av+2
  fin
  proceso LimpiarAvenidaImpar
  variables
    f,p,calle,avenida,av,ca: numero
  comenzar
    av := PosAv
    repetir 4
      Pos(av,1)
      repetir 99
        limpiar(f,p)
        mover
      RecibirMensaje(avenida,rc)
      RecibirMensaje(calle,rc)
      repetir f
        depositar(avenida,calle)
      repetir p
        depositar(avenida,calle)
      av := av+ 2
  fin
  proceso limpiarCuadrante
  variables
    x,y:numero
  comenzar
    x := 40
    y := 40
    Pos(x,y)
    repetir 5
      repetir 5
        mientras (HayFlorEnLaEsquina)
          tomarFlor
        mientras (HayPapelEnLaEsquina)
          tomarPapel
        mover
      Pos(x+1,y)
  fin
