  robot escalonero
  variables
    id,tarea,flores,f,papeles,p: numero
  comenzar
    flores := 0
    papeles := 0
    repetir 3
      RecibirMensaje(tarea,rf)
      si (tarea = 1)
        f := 0
        escalonF(f)
        flores := flores + f
      sino
        p := 0
        escalonP(p)
        papeles  := papeles + p
      repetir 3
        derecha
    repetir flores
      depositarF
    repetir papeles
      depositarP
    EnviarMensaje(id,rf)
    EnviarMensaje(flores,rf)
    EnviarMensaje(papeles,rf)
    EnviarMensaje(V,rf)
  fin
  robot fiscal
  variables
    id,tarea,cantPapeles,cantFlores,flores,papeles:numero
    t: boolean
  comenzar
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    repetir 3
      Random(tarea,1,2)
      EnviarMensaje(tarea,r1)
      Random(tarea,1,2)
      EnviarMensaje(tarea,r2)
      Random(tarea,1,2)
      EnviarMensaje(tarea,r3)
    repetir 3
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(flores,r1)
        cantFlores := cantFlores + flores
        RecibirMensaje(papeles,r1)
        cantPapeles := cantPapeles + papeles
      sino
        si (id = 2)
          RecibirMensaje(flores,r2)
          cantFlores := cantFlores + flores
          RecibirMensaje(papeles,r2)
          cantPapeles := cantPapeles + papeles
        sino
          si (id = 3)
            RecibirMensaje(flores,r3)
            cantFlores := cantFlores + flores
            RecibirMensaje(papeles,r2)
            cantPapeles := cantPapeles + papeles
    repetir 3
      RecibirMensaje(t,*)
    si (cantFlores < cantPapeles)
      buscarFlores
    sino
      buscarPapeles
  fin
