  robot fiscal
  variables
    id,FloresEquipoA,FloresEquipoB,flores:numero
  comenzar
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    EnviarMensaje(4,r4)
    repetir 4
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(flores,r1)
        FloresEquipoA:= FloresEquipoA + flores
      sino
        si (id = 2)
          RecibirMensaje(flores,r2)
          FloresEquipoA:= FloresEquipoA + flores
        sino
          si (id = 3)
            RecibirMensaje(flores,r3)
            FloresEquipoB:= FloresEquipoB + flores
          sino
            si (id = 4)
              RecibirMensaje(flores,r4)
              FloresEquipoB:= FloresEquipoB + flores
    si (FloresEquipoA > FloresEquipoB)
      Informar('gano el equipo A con', FloresEquipoA)
    sino
      si (FloresEquipoA < FloresEquipoB)
        Informar('gano el equipo B con', FloresEquipoB) 
  fin
