procesos
  proceso etapa1(ES f: numero)
  comenzar
    repetir 10
      mientras (HayFlorEnLaEsquina)
        tomarFlor
        f:= f + 1
      mover
    derecha
    repetir 10
      mientras (HayFlorEnLaEsquina)
        tomarFlor
        f:= f + 1
      mover
  fin
