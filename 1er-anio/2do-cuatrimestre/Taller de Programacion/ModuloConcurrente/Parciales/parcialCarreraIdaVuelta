  robot fiscal
  variables
    id,robGanador,flores1,flores2,papeles1,papeles2:numero
  comenzar
    repetir 2
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(flores1,r1)
      sino
        si (id = 2)
          RecibirMensaje(flores2,r2)
    si (flores1>flores2)
      robGanador:= 1
    sino
      si (flores1<flores2)
        robGanador:= 2
    Informar('el rob que junto mas flores fue',robGanador)
    repetir 2
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(papeles1,r1)
      sino
        si (id = 2)
          RecibirMensaje(papeles2,r2)
    si (papeles1>papeles2)
      robGanador:= 1
    sino
      si (papeles1<papeles2)
        robGanador:=2
    Informar('el rob que mas papeles junto fue',robGanador)
  fin
