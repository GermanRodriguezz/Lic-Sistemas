programa ejemplo
procesos
  proceso juntarF(ES f:numero)
  comenzar
    si (HayFlorEnLaEsquina)
      mientras (HayFlorEnLaEsquina)
        tomarFlor
        f:= f + 1
  fin
  proceso juntarP(ES p:numero)
  comenzar
    si (HayPapelEnLaEsquina)
      mientras (HayPapelEnLaEsquina)
        tomarPapel
        p:= p + 1
  fin
  proceso ida(ES f: numero; ES x:numero)
  comenzar
    repetir 4
      juntarF(f)
      x:= x + 1
      mover
  fin
  proceso vuelta(ES p:numero;ES x:numero)
  comenzar
    repetir 4
      juntarP(p)
      x:= x - 1
      mover
  fin
