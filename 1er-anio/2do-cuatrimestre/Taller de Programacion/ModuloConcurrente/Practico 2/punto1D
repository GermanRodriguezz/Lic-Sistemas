procesos
  proceso sacarMaximos(E flor:numero; ES m1:numero; ES m2:numero;E quienEs:numero; ES quienMax:numero)
  comenzar
    si (flor > m1)
      m2:= m1
      m1:= flor
      quienMax:= quienEs
    sino
      m2:= flor
  fin
  proceso juntarF(ES f:numero)
  comenzar
    mientras (HayFlorEnLaEsquina)
      tomarFlor
      f:= f + 1
  fin
  proceso recorrerAvenida(ES flores:numero)
  comenzar
    repetir 9
      juntarF(flores)
      mover
    juntarF(flores)
  fin
