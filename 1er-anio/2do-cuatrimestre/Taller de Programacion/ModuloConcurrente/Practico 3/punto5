programa ejemplo
procesos
  proceso juntar(ES p: numero;ES hay:boolean)
  comenzar
    si (HayPapelEnLaEsquina)
      tomarPapel
      p:= p + 1
    sino
      hay := F
  fin
  proceso depositar(E p:numero)
  comenzar
    si (HayPapelEnLaBolsa)
      depositarPapel
  fin
  proceso actualizarMax(E pos:numero;E NR:numero;ES maxPos:numero; ES RM:numero)
  comenzar
    si (pos > maxPos)
      maxPos:= pos
      RM:= NR
  fin
