robots
  robot corredor
  variables
    haypapel:boolean
    avActual,caActual,p,num:numero
  comenzar
    RecibirMensaje(num,rc)
    p:=0
    haypapel:= V
    mientras(haypapel = V) & (PosCa+1 <= 100)
      avActual:= PosAv
      caActual:= PosCa
      BloquearEsquina(11,11)
      Pos(11,11)
      juntar(p,haypapel)
      Pos(avActual,caActual)
      LiberarEsquina(11,11)
      depositar(p)
      Pos(avActual,caActual+1)
    EnviarMensaje(num,rc)
    EnviarMensaje(caActual,rc)
  fin
  robot coordinador
  variables
    posRob,maxP,quien,quienMax:numero
  comenzar
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3) 
    EnviarMensaje(4,r4)
    maxP:= 0
    repetir 4
      RecibirMensaje(quien,*)
      si(quien = 1)
        RecibirMensaje(posRob,r1)
        actualizarMax(posRob,quien,maxP,quienMax)
      sino
        si (quien = 2)
          RecibirMensaje(posRob,r2)
          actualizarMax(posRob,quien,maxP,quienMax)
        sino
          si(quien = 3)
            RecibirMensaje(posRob,r3)
            actualizarMax(posRob,quien,maxP,quienMax)
          sino
            RecibirMensaje(posRob,r4)
            actualizarMax(posRob,quien,maxP,quienMax)
    Informar('el r que llego mas lejos fue',quienMax)
  fin
