{Bienvenidos al entorno CMRE.
Lo siguiente es un código de ejemplo que implementa un
proceso que recibe un número de avenida como parámetro,
se posiciona en esa avenida y la recorre.}

programa ejemplo
procesos
  proceso juntarF(ES f:numero)
  comenzar
    mientras (HayFlorEnLaEsquina)
      tomarFlor
      f:= f + 1
  fin
  proceso escalonF(ES f:numero; E num:numero)
  comenzar
    repetir num
      mover
    juntarF(f)
    derecha
    repetir num
      mover
    juntarF(f)
    repetir 3
      derecha
  fin
  proceso juntarP(ES p:numero)
  comenzar
    mientras (HayPapelEnLaEsquina)
      tomarPapel
      p:= p + 1
  fin
  proceso escalonP(ES p:numero; E num:numero)
  comenzar
    repetir num
      mover
    juntarP(p)
    repetir 3
      derecha
    repetir num
      mover
    juntarP(p)
    derecha
  fin
areas
  ciudad: AreaP(1,1,100,100)
robots
  robot robot1
  variables
    flores,medida:numero
  comenzar
    flores:=0
    medida := 5
    repetir 5
      escalonF(flores,medida)
      medida := medida - 1
    repetir 3
      derecha
    repetir 6
      escalonF(flores,medida)
      medida := medida + 1
  fin
  robot robot2
  variables
    p,medida:numero
  comenzar
    medida:= 5
    repetir 5
      escalonP(p,medida)
      medida:= medida -1
    derecha
    repetir 6
      escalonP(p,medida)
      medida := medida + 1
  fin
variables
  r1:robot1
  r2:robot2
comenzar
  AsignarArea(r1, ciudad)
  AsignarArea(r2, ciudad)
  Iniciar(r1, 1,1)
  Iniciar(r2, 31,1)
fin