programa ejemplo
areas
  Punto: AreaC (100,1,100,1)
  areaServidor: AreaP (13,1,13,1)
  areaClientes: AreaP (10,1,12,1)
robots
  robot cliente
  variables
    avIni,caIni,cantPapeles,id:numero
  comenzar
    RecibirMensaje(id,rs)
    avIni:= PosAv
    caIni:= PosCa
    repetir 4
      EnviarMensaje(id,rs)
      EnviarMensaje(V,rs)
      RecibirMensaje(cantPapeles,rs)
      BloquearEsquina(100,1)
      repetir cantPapeles
        Pos(100,1)
        si (HayPapelEnLaEsquina)
          tomarPapel
        Pos(avIni,caIni)
        depositarPapel
      LiberarEsquina(100,1)
  fin
  robot servidor
  variables
    avIni,caIni,id,cantPapeles:numero
    pide: boolean
  comenzar
    mientras(HayPapelEnLaEsquina)
      tomarPapel
    avIni:= PosAv
    caIni:= PosCa
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    repetir 12
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(pide,r1)
        Random(cantPapeles,1,5)
        BloquearEsquina(100,1)
        Pos(100,1)
        repetir cantPapeles
          depositarPapel
        Pos(avIni,caIni)
        LiberarEsquina(100,1)
        EnviarMensaje(cantPapeles,r1)
      sino 
        si(id = 2)
          RecibirMensaje(pide,r2)
          Random(cantPapeles,1,5)
          BloquearEsquina(100,1)
          Pos(100,1)
          repetir cantPapeles
            depositarPapel
          Pos(avIni,caIni)
          LiberarEsquina(100,1)
          EnviarMensaje(cantPapeles,r2)
        sino
          si (id = 3)
            RecibirMensaje(pide,r3)
            Random(cantPapeles,1,5)
            BloquearEsquina(100,1)
            Pos(100,1)
            repetir cantPapeles
              depositarPapel
            Pos(avIni,caIni)
            LiberarEsquina(100,1)
            EnviarMensaje(cantPapeles,r3)
  fin
variables
  rs: servidor
  r1: cliente
  r2: cliente
  r3: cliente
comenzar
  AsignarArea(rs, areaServidor)
  AsignarArea(rs, Punto)
  AsignarArea(r1, areaClientes)
  AsignarArea(r1, Punto)
  AsignarArea(r2, areaClientes)
  AsignarArea(r2, Punto)
  AsignarArea(r3, areaClientes)
  AsignarArea(r3, Punto)
  Iniciar(rs,13,1)
  Iniciar(r1,10,1)
  Iniciar(r2,11,1)
  Iniciar(r3,12,1)
fin