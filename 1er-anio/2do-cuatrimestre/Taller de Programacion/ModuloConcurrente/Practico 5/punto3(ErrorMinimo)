programa ejemplo
procesos
  proceso juntar(ES f:numero)
  comenzar
    si (HayFlorEnLaEsquina)
      tomarFlor
      f:= f + 1
  fin
  proceso vaciar(ES f:numero;E av:numero; E ca:numero)
  comenzar
    Pos(10,10)
    mientras (HayFlorEnLaBolsa)
      depositarFlor
      f:= f - 1
    Pos(av,ca)
  fin
  proceso traer(ES cantFlores:numero; E av:numero; E ca:numero)
  comenzar
    Pos(10,10)
    mientras (HayFlorEnLaEsquina)
      tomarFlor
      cantFlores:= cantFlores + 1
    Pos(av,ca)
  fin
areas
  areaCos: AreaP (1,5,1,5)
  areaRec1: AreaP(1,3,100,3)
  areaRec2: AreaP(1,4,100,4)
  Punto: AreaC (10,10,10,10)
robots
  robot recolector
  variables
    flores,mov,avAct,caAct:numero
  comenzar
    flores :=0
    derecha
    mientras (PosAv < 100)
      juntar(flores)
      avAct:= PosAv
      caAct:= PosCa
      si (flores = 10)
        BloquearEsquina(10,10)
        vaciar(flores,avAct,caAct)
        LiberarEsquina(10,10)
        EnviarMensaje(V,rc)
      mov:= mov + 1
      si (mov = 15)
        BloquearEsquina(10,10)
        vaciar(flores,avAct,caAct)
        LiberarEsquina(10,10)
        EnviarMensaje(V,rc)
        mov:= 0
      mover
    EnviarMensaje(F,rc)
  fin
  robot cosechador
  variables
    f,avOri,caOri,cantTerminaron,cantTotal:numero
    b:boolean
  comenzar
    cantTerminaron:=0
    f:= 0
    avOri:= PosAv
    caOri:= PosCa
    mientras (cantTerminaron <> 2)
      RecibirMensaje(b,*)
      si (b = F)
        cantTerminaron := cantTerminaron + 1
      sino
        BloquearEsquina(10,10)
        traer(f,avOri,caOri)
        LiberarEsquina(10,10)
    Informar('las flores son',f)
  fin
variables
  rc: cosechador
  r1: recolector
  r2: recolector
comenzar
  AsignarArea(rc, areaCos)
  AsignarArea(rc,Punto)
  AsignarArea(r1,areaRec1)
  AsignarArea(r1,Punto)
  AsignarArea(r2,areaRec2)
  AsignarArea(r2,Punto)
  Iniciar(rc, 1,5)
  Iniciar(r1,1,3)
  Iniciar(r2,1,4)
fin