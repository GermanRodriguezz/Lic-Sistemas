{Bienvenidos al entorno CMRE.
Lo siguiente es un código de ejemplo que implementa un
proceso que recibe un número de avenida como parámetro,
se posiciona en esa avenida y la recorre.}

programa ejemplo
procesos
  proceso JuntarF(ES flores: numero)
  comenzar
    si (HayFlorEnLaEsquina)
      mientras (HayFlorEnLaEsquina)
        tomarFlor
        flores:= flores + 1
  fin
  proceso JuntarP(ES papeles:numero)
  comenzar
    si (HayPapelEnLaEsquina)
      mientras (HayPapelEnLaEsquina)
        tomarPapel
        papeles := papeles + 1
  fin
areas
  areaRoja: AreaP (2,1,3,100)
  areaAzul: AreaP (98,1,99,100)
  areaJefe: AreaP (1,1,1,1)
robots
  robot equipoRojo
  variables
    f,floresT,id:numero
  comenzar
    RecibirMensaje(id,rj)
    f:=0
    repetir 99
      JuntarF(f)
      floresT:= floresT + f
      mover
    JuntarF(f)
    floresT:= floresT + f
    EnviarMensaje(id,rj)
    EnviarMensaje(floresT,rj)
  fin
  robot equipoAzul
  variables
    id,p,papeles:numero
  comenzar
    RecibirMensaje(id,rj)
    p:= 0
    repetir 99
      JuntarP(p)
      papeles := papeles + p
      mover
    JuntarP(p)
    papeles := papeles + p
    EnviarMensaje(id,rj)
    EnviarMensaje(papeles,rj)
  fin
  robot jefe
  variables
    cantF,cantP,flores1,flores2,papeles1,papeles2,id:numero
  comenzar
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    EnviarMensaje(4,r4)
    cantF:=0
    cantP:=0
    repetir 4
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(flores1,r1)
        cantF:= cantF + flores1
      sino
        si (id = 2)
          RecibirMensaje(flores2,r2)
          cantF:= cantF + flores2
        sino 
          si (id = 3)
            RecibirMensaje(papeles1,r3)
            cantP:= cantP + papeles1
          sino
            si (id = 4)
              RecibirMensaje(papeles2,r4)
              cantP:= cantP + papeles2
    si (cantF > cantP)
      Informar('gano equipo Rojo con', cantF)
    sino
      Informar('gano equipo Azul con',cantP)
  fin
variables
  rj: jefe
  r1: equipoRojo
  r2: equipoRojo
  r3: equipoAzul
  r4: equipoAzul
comenzar
  AsignarArea(rj, areaJefe)
  AsignarArea(r1,areaRoja)
  AsignarArea(r2,areaRoja)
  AsignarArea(r3,areaAzul)
  AsignarArea(r4,areaAzul)
  Iniciar(rj, 1,1)
  Iniciar(r1,2,1)
  Iniciar(r2,3,1)
  Iniciar(r3,98,1)
  Iniciar(r4,99,1)
fin