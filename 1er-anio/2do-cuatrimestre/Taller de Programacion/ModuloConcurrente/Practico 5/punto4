  robot jefe
  variables
    int,Av,Ca,FloresTotales,NumRob:numero
    depositaron: boolean
  comenzar
    int := 0
    repetir 8
      int:= int + 1
      Random(NumRob,1,3)
      Informar('se genero el rob',NumRob)
      Random(Av,40,60)
      Random(Ca,40,60)
      Informar('se genero la esquina',Av,Ca)
      si (NumRob = 1)
        EnviarMensaje(int,r1)
        EnviarMensaje(Av,r1)
        EnviarMensaje(Ca,r1)
      sino
        si (NumRob = 2)
          EnviarMensaje(int,r2)
          EnviarMensaje(Av,r2)
          EnviarMensaje(Ca,r2)
        sino
          si (NumRob = 3)
            EnviarMensaje(int,r3)
            EnviarMensaje(Av,r3)
            EnviarMensaje(Ca,r3)
    EnviarMensaje(9,r1)
    EnviarMensaje(9,r2)
    EnviarMensaje(9,r3)
    repetir 3
      RecibirMensaje(depositaron,*)
    buscarFlores(FloresTotales) 
    Informar('Los robs juntaros', FloresTotales)
  fin
