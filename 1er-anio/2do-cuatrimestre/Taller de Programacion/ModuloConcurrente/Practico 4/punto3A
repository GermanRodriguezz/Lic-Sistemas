programa ejemplo
procesos
  proceso limpiarAvenida(E cant:numero)
  comenzar
    repetir cant
      si (HayPapelEnLaEsquina)
        mientras (HayPapelEnLaEsquina)
          tomarPapel
    mover
  fin
areas
  areaR1: AreaP (1,1,1,100)
  areaR2: AreaP (2,1,2,100)
  areaR3: AreaP (3,1,3,100)
robots
  robot robo1
  variables
    esquinas,calle:numero
    termino: boolean
  comenzar
    mientras(calle < 100)
      esquinas:= 5
      limpiarAvenida(esquinas)
      calle := PosCa
      EnviarMensaje(V,rob2)
      EnviarMensaje(V,rob3)
      RecibirMensaje(termino,rob2)
      RecibirMensaje(termino,rob3)
  fin
