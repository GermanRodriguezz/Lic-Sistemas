robots
  robot robo1
  variables
    esquinas,calle,N,papeles:numero
    termino: boolean
  comenzar
    papeles := 0
    calle := PosCa
    termino := V
    mientras(calle < 100 & termino = V)
      Random(N,1,5)
      Informar('el robo uno junta',N)
      mientras (papeles < N)
        limpiarAvenida(papeles)
        calle := calle + 1
        si (calle < 100)
          mover
        sino
          EnviarMensaje(F,rob2)
          EnviarMensaje(F,rob3)
      papeles := 0
      EnviarMensaje(V,rob2)
      EnviarMensaje(V,rob3)
      RecibirMensaje(termino,rob2)
      RecibirMensaje(termino,rob3)
  fin
